      "maximum": 100,
      "minimum": 0,
      "title": "Signal Score",
      "type": "number"
    },
    "score_breakdown": {
      "$ref": "#/$defs/ScoreBreakdown"
    },
    "support_zone": {
      "anyOf": [
        {
          "$ref": "#/$defs/PriceZone"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "default": "not_available",
      "title": "Support Zone"
    },
    "allowed_entry_range": {
      "anyOf": [
        {
          "$ref": "#/$defs/PriceZone"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "default": "not_available",
      "title": "Allowed Entry Range"
    },
    "planned_entry_price": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "default": "not_available",
      "title": "Planned Entry Price"
    },
    "entry_zone": {
      "anyOf": [
        {
          "$ref": "#/$defs/PriceZone"
        },
        {
          "const": "not_available",
          "type": "string"
        }
