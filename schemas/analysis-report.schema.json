    "target_sources": {
      "items": {
        "type": "string"
      },
      "title": "Target Sources",
      "type": "array"
    },
    "trailing_stop_method": {
      "title": "Trailing Stop Method",
      "type": "string"
    },
    "risk_reward_ratio": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "title": "Risk Reward Ratio"
    },
    "suggested_position_size": {
      "anyOf": [
        {
          "$ref": "#/$defs/PositionSuggestion"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "title": "Suggested Position Size"
    },
    "maximum_loss_amount": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "title": "Maximum Loss Amount"
