    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "invalidation_conditions": {
      "items": {
        "type": "string"
      },
      "title": "Invalidation Conditions",
      "type": "array"
    },
    "missing_data": {
      "additionalProperties": {
        "const": "not_available",
        "type": "string"
      },
      "title": "Missing Data",
      "type": "object"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "disclaimer": {
      "default": "策略研究结果，不是收益保证，也不是投资建议。",
