{
  "$defs": {
    "DataFreshnessItem": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/FreshnessStatus"
        },
        "expected_latest_close": {
          "format": "date-time",
          "title": "Expected Latest Close",
          "type": "string"
        },
        "actual_latest_close": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Actual Latest Close"
        },
        "staleness_seconds": {
          "minimum": 0,
          "title": "Staleness Seconds",
          "type": "number"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        }
      },
      "required": [
        "status",
        "expected_latest_close",
        "actual_latest_close",
        "staleness_seconds"
      ],
      "title": "DataFreshnessItem",
      "type": "object"
    },
    "DataQuality": {
      "additionalProperties": false,
      "properties": {
        "grade": {
          "$ref": "#/$defs/QualityGrade"
        },
        "bars": {
          "minimum": 0,
          "title": "Bars",
          "type": "integer"
        },
        "expected_interval": {
          "title": "Expected Interval",
          "type": "string"
        },
        "duplicate_count": {
          "minimum": 0,
          "title": "Duplicate Count",
          "type": "integer"
        },
        "gap_count": {
          "minimum": 0,
          "title": "Gap Count",
          "type": "integer"
        },
        "missing_intervals": {
          "items": {
            "type": "string"
          },
          "title": "Missing Intervals",
          "type": "array"
        },
        "issues": {
          "items": {
            "type": "string"
          },
          "title": "Issues",
          "type": "array"
        }
      },
      "required": [
        "grade",
        "bars",
        "expected_interval",
        "duplicate_count",
        "gap_count"
      ],
      "title": "DataQuality",
      "type": "object"
    },
    "FreshnessStatus": {
      "enum": [
        "fresh",
        "stale",
        "missing",
        "invalid"
      ],
      "title": "FreshnessStatus",
      "type": "string"
    },
    "IndicatorSnapshot": {
      "additionalProperties": false,
      "properties": {
        "close": {
          "title": "Close",
          "type": "number"
        },
        "ema20": {
          "title": "Ema20",
          "type": "number"
        },
        "ema50": {
          "title": "Ema50",
          "type": "number"
        },
        "ema200": {
          "title": "Ema200",
          "type": "number"
        },
        "rsi14": {
          "title": "Rsi14",
          "type": "number"
        },
        "macd": {
          "title": "Macd",
          "type": "number"
        },
        "macd_signal": {
          "title": "Macd Signal",
          "type": "number"
        },
        "macd_histogram": {
          "title": "Macd Histogram",
          "type": "number"
        },
        "atr14": {
          "title": "Atr14",
          "type": "number"
        },
        "adx14": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "const": "not_available",
              "type": "string"
            }
          ],
          "title": "Adx14"
        },
        "volume_ratio": {
          "title": "Volume Ratio",
          "type": "number"
        }
      },
      "required": [
        "close",
        "ema20",
        "ema50",
        "ema200",
        "rsi14",
        "macd",
        "macd_signal",
        "macd_histogram",
        "atr14",
        "adx14",
        "volume_ratio"
      ],
      "title": "IndicatorSnapshot",
      "type": "object"
    },
    "MarketRegime": {
      "enum": [
        "bull_trend",
        "bull_pullback",
        "sideways_range",
        "bear_trend",
        "bear_capitulation",
        "bear_recovery"
      ],
      "title": "MarketRegime",
      "type": "string"
    },
    "PositionSuggestion": {
      "additionalProperties": false,
      "properties": {
        "quantity": {
          "minimum": 0,
          "title": "Quantity",
          "type": "number"
        },
        "position_notional_cny": {
          "minimum": 0,
          "title": "Position Notional Cny",
          "type": "number"
        },
        "risk_amount_cny": {
          "minimum": 0,
          "title": "Risk Amount Cny",
          "type": "number"
        },
        "position_fraction": {
          "maximum": 1,
          "minimum": 0,
          "title": "Position Fraction",
          "type": "number"
        },
        "quote_to_account_rate": {
          "exclusiveMinimum": 0,
          "title": "Quote To Account Rate",
          "type": "number"
        },
        "entry_price": {
          "exclusiveMinimum": 0,
          "title": "Entry Price",
          "type": "number"
        },
        "stop_price": {
          "exclusiveMinimum": 0,
          "title": "Stop Price",
          "type": "number"
        },
        "minimum_notional": {
          "minimum": 0,
          "title": "Minimum Notional",
          "type": "number"
        },
        "quantity_step_size": {
          "exclusiveMinimum": 0,
          "title": "Quantity Step Size",
          "type": "number"
        }
      },
      "required": [
        "quantity",
        "position_notional_cny",
        "risk_amount_cny",
        "position_fraction",
        "quote_to_account_rate",
        "entry_price",
        "stop_price",
        "minimum_notional",
        "quantity_step_size"
      ],
      "title": "PositionSuggestion",
      "type": "object"
    },
    "PriceZone": {
      "additionalProperties": false,
      "properties": {
        "lower_price": {
          "exclusiveMinimum": 0,
          "title": "Lower Price",
          "type": "number"
        },
        "upper_price": {
          "exclusiveMinimum": 0,
          "title": "Upper Price",
          "type": "number"
        },
        "center_price": {
          "exclusiveMinimum": 0,
          "title": "Center Price",
          "type": "number"
        },
        "level_type": {
          "enum": [
            "support",
            "resistance"
          ],
          "title": "Level Type",
          "type": "string"
        },
        "timeframe": {
          "title": "Timeframe",
          "type": "string"
        },
        "touch_count": {
          "minimum": 1,
          "title": "Touch Count",
          "type": "integer"
        },
        "reaction_count": {
          "default": 0,
          "minimum": 0,
          "title": "Reaction Count",
          "type": "integer"
        },
        "break_count": {
          "default": 0,
          "minimum": 0,
          "title": "Break Count",
          "type": "integer"
        },
        "last_touch_time": {
          "format": "date-time",
          "title": "Last Touch Time",
          "type": "string"
        },
        "strength_score": {
          "maximum": 100,
          "minimum": 0,
          "title": "Strength Score",
          "type": "number"
        },
        "evidence": {
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        }
      },
      "required": [
        "lower_price",
        "upper_price",
        "center_price",
        "level_type",
        "timeframe",
        "touch_count",
        "last_touch_time",
        "strength_score",
        "evidence"
      ],
      "title": "PriceZone",
      "type": "object"
    },
    "QualityGrade": {
      "enum": [
        "valid",
        "degraded",
        "invalid"
      ],
      "title": "QualityGrade",
      "type": "string"
    },
    "ScoreBreakdown": {
      "additionalProperties": false,
      "properties": {
        "higher_timeframe_trend": {
          "maximum": 20,
          "minimum": 0,
          "title": "Higher Timeframe Trend",
          "type": "number"
        },
        "support_resistance": {
          "maximum": 25,
          "minimum": 0,
          "title": "Support Resistance",
          "type": "number"
        },
        "candlestick_confirmation": {
          "maximum": 15,
          "minimum": 0,
          "title": "Candlestick Confirmation",
          "type": "number"
        },
        "volume_confirmation": {
          "maximum": 15,
          "minimum": 0,
          "title": "Volume Confirmation",
          "type": "number"
        },
        "indicator_confirmation": {
          "maximum": 15,
          "minimum": 0,
          "title": "Indicator Confirmation",
          "type": "number"
        },
        "reward_risk_space": {
          "maximum": 10,
          "minimum": 0,
          "title": "Reward Risk Space",
          "type": "number"
        },
        "sentiment_adjustment": {
          "default": 0,
          "maximum": 5,
          "minimum": -5,
          "title": "Sentiment Adjustment",
          "type": "number"
        }
      },
      "required": [
        "higher_timeframe_trend",
        "support_resistance",
        "candlestick_confirmation",
        "volume_confirmation",
        "indicator_confirmation",
        "reward_risk_space"
      ],
      "title": "ScoreBreakdown",
      "type": "object"
    },
    "SignalLabel": {
      "enum": [
        "strong_buy_candidate",
        "buy_candidate",
        "watch",
        "no_trade"
      ],
      "title": "SignalLabel",
      "type": "string"
    },
    "StrategyHorizon": {
      "enum": [
        "short_term",
        "medium_term",
        "long_term"
      ],
      "title": "StrategyHorizon",
      "type": "string"
    },
    "SymbolTradingRules": {
      "additionalProperties": false,
      "properties": {
        "symbol": {
          "title": "Symbol",
          "type": "string"
        },
        "price_tick_size": {
          "exclusiveMinimum": 0,
          "title": "Price Tick Size",
          "type": "number"
        },
        "quantity_step_size": {
          "exclusiveMinimum": 0,
          "title": "Quantity Step Size",
          "type": "number"
        },
        "minimum_quantity": {
          "minimum": 0,
          "title": "Minimum Quantity",
          "type": "number"
        },
        "maximum_quantity": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Quantity"
        },
        "minimum_notional": {
          "minimum": 0,
          "title": "Minimum Notional",
          "type": "number"
        },
        "fetched_at": {
          "format": "date-time",
          "title": "Fetched At",
          "type": "string"
        },
        "data_source": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "symbol",
        "price_tick_size",
        "quantity_step_size",
        "minimum_quantity",
        "minimum_notional",
        "fetched_at",
        "data_source"
      ],
      "title": "SymbolTradingRules",
      "type": "object"
    },
    "Trend": {
      "enum": [
        "bullish",
        "bearish",
        "sideways"
      ],
      "title": "Trend",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "default": "1.3.0",
      "title": "Schema Version",
      "type": "string"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "requested_at": {
      "format": "date-time",
      "title": "Requested At",
      "type": "string"
    },
    "evaluation_time": {
      "format": "date-time",
      "title": "Evaluation Time",
      "type": "string"
    },
    "evaluation_timeframe": {
      "const": "4h",
      "default": "4h",
      "title": "Evaluation Timeframe",
      "type": "string"
    },
    "time_alignment_applied": {
      "title": "Time Alignment Applied",
      "type": "boolean"
    },
    "latest_completed_candle_close": {
      "additionalProperties": {
        "format": "date-time",
        "type": "string"
      },
      "title": "Latest Completed Candle Close",
      "type": "object"
    },
    "data_freshness": {
      "additionalProperties": {
        "$ref": "#/$defs/DataFreshnessItem"
      },
      "title": "Data Freshness",
      "type": "object"
    },
    "freshness_retry_attempts": {
      "minimum": 0,
      "title": "Freshness Retry Attempts",
      "type": "integer"
    },
    "symbol": {
      "title": "Symbol",
      "type": "string"
    },
    "market": {
      "const": "binance_spot",
      "default": "binance_spot",
      "title": "Market",
      "type": "string"
    },
    "data_source": {
      "title": "Data Source",
      "type": "string"
    },
    "analysis_timeframes": {
      "items": {
        "type": "string"
      },
      "title": "Analysis Timeframes",
      "type": "array"
    },
    "current_price": {
      "exclusiveMinimum": 0,
      "title": "Current Price",
      "type": "number"
    },
    "account_currency": {
      "default": "CNY",
      "enum": [
        "CNY",
        "USDT"
      ],
      "title": "Account Currency",
      "type": "string"
    },
    "account_equity_cny": {
      "minimum": 0,
      "title": "Account Equity Cny",
      "type": "number"
    },
    "risk_locks": {
      "items": {
        "type": "string"
      },
      "title": "Risk Locks",
      "type": "array"
    },
    "trading_rules": {
      "anyOf": [
        {
          "$ref": "#/$defs/SymbolTradingRules"
        },
        {
          "const": "not_available",
          "type": "string"
        }
      ],
      "title": "Trading Rules"
    },
    "trading_rules_status": {
      "enum": [
        "available",
        "exchange_rules_unavailable",
        "exchange_rules_stale_cache"
      ],
      "title": "Trading Rules Status",
      "type": "string"
    },
    "data_quality": {
      "additionalProperties": {
        "$ref": "#/$defs/DataQuality"
      },
      "title": "Data Quality",
      "type": "object"
    },
    "daily_trend": {
      "$ref": "#/$defs/Trend"
    },
    "four_hour_trend": {
      "$ref": "#/$defs/Trend"
    },
    "one_hour_trend": {
      "$ref": "#/$defs/Trend"
    },
    "market_regime": {
      "$ref": "#/$defs/MarketRegime"
    },
    "regime_evidence": {
      "items": {
        "type": "string"
      },
      "title": "Regime Evidence",
      "type": "array"
    },
    "selected_strategy": {
      "title": "Selected Strategy",
      "type": "string"
    },
    "strategy_horizon": {
      "$ref": "#/$defs/StrategyHorizon"
    },
    "entry_setup": {
      "title": "Entry Setup",
      "type": "string"
    },
    "candidate_tier": {
      "enum": [
        "A",
        "B",
        "none"
      ],
      "title": "Candidate Tier",
      "type": "string"
    },
    "risk_multiplier": {
      "maximum": 1,
      "minimum": 0,
      "title": "Risk Multiplier",
      "type": "number"
    },
    "confirmation_score": {
      "minimum": 0,
      "title": "Confirmation Score",
      "type": "number"
    },
    "strong_confirmation_count": {
      "minimum": 0,
      "title": "Strong Confirmation Count",
      "type": "integer"
    },
    "one_hour_confirmation": {
      "title": "One Hour Confirmation",
      "type": "string"
    },
    "support_zones": {
      "items": {
        "$ref": "#/$defs/PriceZone"
      },
      "title": "Support Zones",
      "type": "array"
    },
    "resistance_zones": {
      "items": {
        "$ref": "#/$defs/PriceZone"
      },
      "title": "Resistance Zones",
      "type": "array"
    },
    "indicators": {
      "additionalProperties": {
        "$ref": "#/$defs/IndicatorSnapshot"
      },
      "title": "Indicators",
      "type": "object"
    },
    "signal": {
      "$ref": "#/$defs/SignalLabel"
