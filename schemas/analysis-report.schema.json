{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nvnmvm/crypto-strategy-analyst/schemas/analysis-report.schema.json",
  "title": "Crypto Strategy Analyst report 2.0",
  "type": "object",
  "required": ["schema_version", "generated_at", "profile", "market", "data_availability", "scores", "confidence", "key_levels", "relative_strength", "plans", "events", "chart_data", "warnings", "limitations"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "profile": {"enum": ["btc", "eth", "bnb", "sol", "generic"]},
    "market": {"type": "object"},
    "data_availability": {"type": "object"},
    "scores": {"type": "object"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 100},
    "key_levels": {"type": "array"},
    "relative_strength": {"type": "object"},
    "plans": {"type": "object", "required": ["short", "swing", "long"]},
    "events": {"type": "array"},
    "chart_data": {"type": "object"},
    "warnings": {"type": "array"},
    "limitations": {"type": "array"},
    "hard_filters": {"type": "array"}
  },
  "additionalProperties": false
}
