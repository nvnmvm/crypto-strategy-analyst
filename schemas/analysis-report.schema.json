    "data_quality",
    "daily_trend",
    "four_hour_trend",
    "one_hour_trend",
    "market_regime",
    "regime_evidence",
    "selected_strategy",
    "strategy_horizon",
    "entry_setup",
    "candidate_tier",
    "risk_multiplier",
